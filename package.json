{
  "name": "annas-book-downloader",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "annas-download": "./bin/annas-download.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "start": "tsx commands/cli.ts",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx commands/cli.ts",
    "search": "tsx scripts/cli-search.ts",
    "download": "tsx scripts/cli-download.ts",
    "batch": "tsx scripts/cli-batch.ts",
    "cli": "tsx commands/cli.ts",
    "link": "npm run build && npm link"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "execa": "^9.6.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
